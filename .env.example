# ==========================================
# Antigravity Website - Environment Variables
# ==========================================

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/antigravity?retryWrites=true&w=majority

# JWT
JWT_SECRET=buraya-cok-guclu-bir-secret-key-yaz-en-az-32-karakter

# Admin Credentials (for seed script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=buraya-guclu-bir-sifre-yaz

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS — comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
